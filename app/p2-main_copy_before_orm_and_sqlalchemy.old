# ============ IMPORTS ============
# FastAPI: Main web framework for building REST APIs with automatic validation, documentation, and async support
# Body: Explicit request body parameter marker (rarely needed since BaseModel implies it)
# Response: Object to customize HTTP responses (status codes, headers, cookies). Used for manual control when needed
# status: HTTP status code constants (200, 201, 404, 422, etc.) - more readable than raw numbers
# HTTPException: FastAPI's exception class that automatically converts to proper HTTP error responses with status codes
# BaseModel: Pydantic class for data validation schemas. FastAPI uses this to parse/validate request data
# Optional: Type hint meaning a value can be None or the specified type. FastAPI makes these parameters optional in APIs
from fastapi import Body, FastAPI , Response, status , HTTPException
from pydantic import BaseModel
from typing import Optional
from random import randrange
import psycopg2
from  psycopg2.extras import RealDictCursor
import time

# ============ APP INITIALIZATION ============
# Create FastAPI app instance - this is your entire API application
# All endpoints (@app.get, @app.post, @app.delete, etc.) are registered with this instance
# FastAPI automatically generates OpenAPI docs, JSON Schema, and handles routing to the right handler function
app = FastAPI()

# ============ DATA MODELS ============
# Define a Post model using Pydantic - acts as a schema/contract for API requests and responses
# When a request is received with JSON body, FastAPI automatically:
# 1. Parses raw JSON string from HTTP request body
# 2. Validates each field against this schema (type checking, required vs optional)
# 3. Converts validated JSON into a Post object instance
# 4. If validation fails, returns 422 Unprocessable Entity with error details (automatic!)
# 
# This model also serves as AUTO-DOCUMENTATION - FastAPI shows this in interactive docs at /docs
class Post(BaseModel):
  title: str                          # Required field - MUST be provided in JSON, must be a string type
  content: str                        # Required field - MUST be provided in JSON, must be a string type
  published: bool = True              # Optional field with default - if not provided, defaults to True
  
  # rating: Optional[int] = None        # Optional field that can be None or an integer - safe to omit from request
while True :
  try:
    conn = psycopg2.connect(host='localhost', database='fastapi', user='postgres', password='postgreSunkale@1403' , cursor_factory=RealDictCursor)
    cursor = conn.cursor()
    print("Database connection successful!")
    break
  except Exception as error:
    print("Database connection failed:", error)
    time.sleep(10) # Wait for 10 seconds before retrying

  
  
my_posts = [{"title": "First Post", "content": "This is the content of the first post", "published": True, "rating": 5, "id": 1},{"title": "Fav Foods", "content": "This is the content of the fav foods", "published": False, "rating": 3, "id": 2}] # Legacy in-memory data store (deprecated - all data operations now use PostgreSQL database via cursor)

def find_post(id):
  # ========== SQL QUERY - SELECT BY PRIMARY KEY ==========
  # Query: SELECT * FROM posts WHERE id = %s
  # PURPOSE: Fetch a single post by its primary key ID from the database
  # PARAMETERIZED QUERY: Uses %s placeholder with (str(id),) tuple to prevent SQL injection
  # WHY TUPLE: psycopg2 requires parameters as tuple. The trailing comma (str(id),) makes it a 1-element tuple
  # EXECUTION: Database finds exact match on id (indexed column) for O(1) lookup performance
  cursor.execute("SELECT * FROM posts WHERE id = %s", (str(id),))
  
  # ========== FETCH RESULT ==========
  # cursor.fetchone(): Retrieves ONE row from result set and returns as dict (because cursor_factory=RealDictCursor)
  # Returns: dict with columns as keys (id, title, content, published) OR None if no match found
  # Note: Result sits in cursor buffer after execute() - fetchone() retrieves from memory, not making new query
  post = cursor.fetchone()
  return post # Returns the post dict if found, or None if not found

