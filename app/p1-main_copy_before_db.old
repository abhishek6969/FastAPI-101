# ============ IMPORTS ============
# FastAPI: Main web framework for building REST APIs with automatic validation, documentation, and async support
# Body: Explicit request body parameter marker (rarely needed since BaseModel implies it)
# Response: Object to customize HTTP responses (status codes, headers, cookies). Used for manual control when needed
# status: HTTP status code constants (200, 201, 404, 422, etc.) - more readable than raw numbers
# HTTPException: FastAPI's exception class that automatically converts to proper HTTP error responses with status codes
# BaseModel: Pydantic class for data validation schemas. FastAPI uses this to parse/validate request data
# Optional: Type hint meaning a value can be None or the specified type. FastAPI makes these parameters optional in APIs
from fastapi import Body, FastAPI , Response, status , HTTPException
from pydantic import BaseModel
from typing import Optional
from random import randrange

# ============ APP INITIALIZATION ============
# Create FastAPI app instance - this is your entire API application
# All endpoints (@app.get, @app.post, @app.delete, etc.) are registered with this instance
# FastAPI automatically generates OpenAPI docs, JSON Schema, and handles routing to the right handler function
app = FastAPI()

# ============ DATA MODELS ============
# Define a Post model using Pydantic - acts as a schema/contract for API requests and responses
# When a request is received with JSON body, FastAPI automatically:
# 1. Parses raw JSON string from HTTP request body
# 2. Validates each field against this schema (type checking, required vs optional)
# 3. Converts validated JSON into a Post object instance
# 4. If validation fails, returns 422 Unprocessable Entity with error details (automatic!)
# 
# This model also serves as AUTO-DOCUMENTATION - FastAPI shows this in interactive docs at /docs
class Post(BaseModel):
  title: str                          # Required field - MUST be provided in JSON, must be a string type
  content: str                        # Required field - MUST be provided in JSON, must be a string type
  published: bool = True              # Optional field with default - if not provided, defaults to True
  rating: Optional[int] = None        # Optional field that can be None or an integer - safe to omit from request
  

  
  
my_posts = [{"title": "First Post", "content": "This is the content of the first post", "published": True, "rating": 5, "id": 1},{"title": "Fav Foods", "content": "This is the content of the fav foods", "published": False, "rating": 3, "id": 2}] # Sample in-memory data store for posts (not used in current routes but can be extended later)

def find_post(id):
  return next((my_post for my_post in my_posts if my_post["id"] == id), None)

def find_index_post(id):
  for index, post in enumerate(my_posts):
    if post["id"] == id:
      return index
  return None

# ============ ROUTES - GET REQUESTS ============
# @app.get("/") - decorator that registers a GET endpoint at root URL (/)
# This function is called when a GET request hits the root path
@app.get("/")
def root():
  return {"message": "My name is Abhishek!"}

# @app.get("/posts") - GET endpoint that returns all posts
# In a real app, this would fetch from a database
@app.get("/posts")
def get_posts():
  return {"data": my_posts}

@app.get("/posts/{id}") # Dynamic route placeholder {id} is extracted from URL
def get_post(id: int , response: Response): # 'id' is expected to be an integer (validated by FastAPI)
  # The fastapi framework automatically validates and converts the 'id' path parameter to an integer before it reaches this function because we specified 'id: int' in the function signature. This means: fastapi will check if the value in the URL can be converted to an integer. If it can, it will pass the integer
  
  # ========== PYDANTIC VALIDATION FOR PATH PARAMETER ==========
  # When URL is accessed: GET /posts/5 or GET /posts/123
  #
  # STEP 1: FastAPI extracts the path parameter from URL:
  #   URL: "http://127.0.0.1:8000/posts/5"
  #   Extracted value: "5" (comes as STRING from URL)
  #
  # STEP 2: Pydantic validates and converts STRING → INTEGER:
  #   - Checks if "5" can be converted to an integer ✓
  #   - If it CAN be converted: passes 5 (int) to function
  #   - If it CANNOT (e.g., "abc"): returns 422 error immediately
  #
  # RESULT: The 'id' parameter is a validated integer, NOT a string!
  # Example: /posts/5 → id = 5 (int type)
  # Example: /posts/abc → Error 422 (validation failed)
  
  my_post = find_post(id) # Search in-memory database for post with this ID
  if not my_post: # If no post found with the given ID
      # HTTPException is FastAPI's way to gracefully return HTTP error responses
      # When raised, FastAPI automatically:
      # 1. Converts this to proper HTTP response with specified status code
      # 2. Sends the detail message as JSON response body
      # 3. Sets appropriate Content-Type and status headers
      # This is better than manually setting response.status_code because:
      # - More Pythonic (exception-based control flow)
      # - Automatic error formatting and headers
      # - Stops function execution immediately
      raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail=f"Post with id: {id} was not found")
  return {"post_data" : my_post}

# ============ ROUTES - POST REQUESTS ============
# @app.post("/posts") registers a POST HTTP method handler for the /posts path
# POST method = used for CREATING new resources (RESTful convention)
# @app.post decorator tells FastAPI:
#   1. Listen for POST requests to /posts
#   2. Extract request body, validate it using Post model schema
#   3. Pass validated Post object to this function
#   4. Auto-serialize the returned dict to JSON response
#
# status_code parameter in DECORATOR is declarative (FastAPI's best practice)
# This tells FastAPI to ALWAYS return 201 Created status for successful requests
# (Better than manually setting in function because it's visible in docs and handled before function runs)
@app.post("/posts", status_code=status.HTTP_201_CREATED)  # 201 Created = standard HTTP status for successful resource creation
def create_post(post: Post): # 'post: Post' triggers automatic Pydantic validation of request body
  # ========== REQUEST BODY FLOW ==========
  # Client sends: POST /posts with JSON body
  # FastAPI receives: raw JSON string from HTTP request
  # Pydantic validates: parses JSON string → Python dict → validates against Post schema
  # Function receives: validated Post object (strongly typed, all fields confirmed valid)
  # Function returns: Python dict → FastAPI serializes to JSON → sends HTTP response
  
  post_dict = post.model_dump() # Convert Pydantic Post object to plain Python dictionary
  # (Useful because we're storing as dict in memory, not as Pydantic objects)
  post_dict["id"] = randrange(0, 1000000) # Generate simulated unique ID (real DB would auto-generate)
  my_posts.append(post_dict) # Append new post to in-memory list (simulates database INSERT)
  # Return dict which FastAPI auto-converts to JSON and sends with 201 status
  return {"data": post_dict}

#Visit http://127.0.0.1:8000/docs to view the interactive API documentation 
#always use plural for posts / users as its  abest practice to follow RESTful conventions.

# ============ ROUTES - DELETE REQUESTS ============
# @app.delete registers a DELETE HTTP method handler
# DELETE method = used for REMOVING/DELETING resources (RESTful convention)
# status_code=204 indicates successful deletion with NO content in response body
# (Different from 200 OK which usually has a response body)
@app.delete("/posts/{id}", status_code=status.HTTP_204_NO_CONTENT)  # 204 No Content = standard for successful DELETE
def delete_post(id: int):  # Path parameter 'id' is validated and converted to int by Pydantic (like in GET)
  # Find the INDEX of the post (not just existence check)
  # We need index because Python list.pop(index) requires index, not the value
  index = find_index_post(id)
  
  if index is None:  # If post doesn't exist, raise 404 error
    # FastAPI converts this exception to 404 HTTP response automatically
    raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail=f"Post with id: {id} was not found")
  
  my_posts.pop(index)  # Remove the post from the list by index
  # Return Response object with 204 status
  # 204 means deletion successful, no response body needed (just status line)
  # FastAPI will not try to JSON-serialize any response body
  return Response(status_code=status.HTTP_204_NO_CONTENT)


@app.put("/posts/{id}",status_code=status.HTTP_200_OK) # PUT method = used for UPDATING existing resources (RESTful convention)
def update_post(id: int, post: Post): # 'id' from path, 'post' from request body (validated by Pydantic)
  index = find_index_post(id)
  
  if index is None:  # If post doesn't exist, raise 404 error
    raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail=f"Post with id: {id} was not found")
  
  post_dict = post.model_dump()
  post_dict["id"] = id
  my_posts[index] = post_dict
  return {"data": post_dict}

#use /redoc for alternative API documentation style (more detailed, better for large APIs)
#We place this in app folder which has __init__.py file to make it a package, and we can run it with uvicorn main:app to start the server. Start it using the command app.main:app because we are inside the app package and main.py is the module that contains the FastAPI instance named 'app'.